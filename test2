local KavoGui = CoreGui:FindFirstChild("Kavo UI") 
    or LocalPlayer.PlayerGui:FindFirstChild("Kavo UI")

if KavoGui then
    local function findBar(parent)
        for _, v in pairs(parent:GetDescendants()) do
            if v:IsA("Frame") and (v.Name == "TopBar" or v.Name == "Bar" or v.Name == "DragBar") then
                return v
            end
        end
    end

    local bar = findBar(KavoGui)

    if bar then
        local Logo = Instance.new("ImageLabel")
        Logo.Name = "DestinyLogo"
        Logo.Size = UDim2.new(0, 30, 0, 30)
        Logo.Position = UDim2.new(0, 6, 0.5, -15)
        Logo.BackgroundTransparency = 1
        Logo.Image = "rbxassetid://YOUR_ASSET_ID" -- << ใส่ Asset ID ของรูปคุณ
        Logo.ImageColor3 = Color3.fromRGB(255, 255, 255)
        Logo.ZIndex = 10
        Logo.Parent = bar

        local Glow = Instance.new("ImageLabel")
        Glow.Size = UDim2.new(0, 50, 0, 50)
        Glow.Position = UDim2.new(0, -4, 0.5, -25)
        Glow.BackgroundTransparency = 1
        Glow.Image = "rbxassetid://5028857084"
        Glow.ImageColor3 = Color3.fromRGB(120, 80, 255)
        Glow.ImageTransparency = 0.4
        Glow.ZIndex = 9
        Glow.Parent = bar

        task.spawn(function()
            local t = 0
            while Logo and Logo.Parent do
                t = t + 0.05
                Glow.ImageTransparency = 0.3 + math.sin(t) * 0.15
                task.wait(0.03)
            end
        end)
    end
end

