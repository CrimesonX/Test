-- ===[ ESP SYSTEM ]===
local ESPFolder = Instance.new("Folder")
ESPFolder.Name = "DestinyESP"
ESPFolder.Parent = CoreGui

local function CreateESP(player)
    if player == LocalPlayer then return end

    local function onCharacter(character)
        local old = ESPFolder:FindFirstChild(player.Name)
        if old then old:Destroy() end

        local container = Instance.new("Folder")
        container.Name = player.Name
        container.Parent = ESPFolder

        local humanoid = character:WaitForChild("Humanoid", 5)
        local hrp = character:WaitForChild("HumanoidRootPart", 5)
        if not humanoid or not hrp then return end

        -- BillboardGui
        local billboard = Instance.new("BillboardGui")
        billboard.AlwaysOnTop = true
        billboard.Size = UDim2.new(0, 60, 0, 90)
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.Adornee = hrp
        billboard.Enabled = false
        billboard.Parent = container

        -- Box
        local box = Instance.new("Frame")
        box.Size = UDim2.new(1, 0, 1, 0)
        box.BackgroundTransparency = 1
        box.Parent = billboard

        local uiStroke = Instance.new("UIStroke")
        uiStroke.Color = _G.ESPColor or Color3.fromRGB(170, 0, 255)
        uiStroke.Thickness = 1.5
        uiStroke.Parent = box

        -- Name
        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, 0, 0, 16)
        nameLabel.Position = UDim2.new(0, 0, -0.22, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.TextColor3 = _G.ESPColor or Color3.fromRGB(170, 0, 255)
        nameLabel.TextStrokeTransparency = 0
        nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextSize = 12
        nameLabel.Text = player.Name
        nameLabel.Parent = billboard

        -- HP Bar BG
        local hpBarBG = Instance.new("Frame")
        hpBarBG.Size = UDim2.new(0, 5, 1, 0)
        hpBarBG.Position = UDim2.new(-0.12, 0, 0, 0)
        hpBarBG.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        hpBarBG.BorderSizePixel = 0
        hpBarBG.Parent = billboard

        -- HP Bar
        local hpBar = Instance.new("Frame")
        hpBar.Size = UDim2.new(1, 0, 1, 0)
        hpBar.AnchorPoint = Vector2.new(0, 1)
        hpBar.Position = UDim2.new(0, 0, 1, 0)
        hpBar.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        hpBar.BorderSizePixel = 0
        hpBar.Parent = hpBarBG

        -- Distance
        local distLabel = Instance.new("TextLabel")
        distLabel.Size = UDim2.new(1, 0, 0, 14)
        distLabel.Position = UDim2.new(0, 0, 1.05, 0)
        distLabel.BackgroundTransparency = 1
        distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        distLabel.TextStrokeTransparency = 0
        distLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        distLabel.Font = Enum.Font.Gotham
        distLabel.TextSize = 10
        distLabel.Text = "0m"
        distLabel.Parent = billboard

        -- Update Loop
        task.spawn(function()
            while container and container.Parent do
                task.wait(0.05)

                local espOn = _G.ESP == true
                billboard.Enabled = espOn

                if not espOn then continue end

                local col = _G.ESPColor or Color3.fromRGB(170, 0, 255)
                uiStroke.Color = col
                nameLabel.TextColor3 = col
                nameLabel.Visible = _G.ESPNames ~= false
                hpBarBG.Visible = _G.ESPHealth ~= false

                if humanoid and humanoid.Parent then
                    local pct = humanoid.Health / math.max(humanoid.MaxHealth, 1)
                    hpBar.Size = UDim2.new(1, 0, pct, 0)
                    hpBar.BackgroundColor3 = Color3.fromRGB(
                        math.floor(255 * (1 - pct)),
                        math.floor(255 * pct),
                        50
                    )
                end

                local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if myHRP and hrp and hrp.Parent then
                    distLabel.Text = math.floor((myHRP.Position - hrp.Position).Magnitude) .. "m"
                else
                    distLabel.Text = "?"
                end
            end
        end)

        humanoid.Died:Connect(function()
            task.wait(2)
            if container then container:Destroy() end
        end)
    end

    if player.Character then
        task.spawn(onCharacter, player.Character)
    end
    player.CharacterAdded:Connect(onCharacter)
end

for _, p in pairs(Players:GetPlayers()) do
    task.spawn(CreateESP, p)
end

Players.PlayerAdded:Connect(CreateESP)

